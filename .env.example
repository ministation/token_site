# PostgreSQL база данных игры
DB_HOST=IP
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=your_password_here

# Discord OAuth2 (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://your-server-ip:8067/callback

# Discord ID администраторов через запятую
ADMIN_ROLE_IDS=

# Настройки банка
BANK_DEPOSIT_MIN=10
BANK_DEPOSIT_RATE=20
BANK_DEPOSIT_DAYS=7
BANK_LOAN_MAX=50
BANK_LOAN_RATE=30
BANK_LOAN_DAYS=7

# Лотерея
LOTTERY_COST=5

# Переводы
MIN_TRANSFER=1
TRANSFER_COOLDOWN=60

# Чат
MAX_CHAT_MESSAGES=100

# Сервер
SERVER_HOST=0.0.0.0
SERVER_PORT=8067

# Пути к файлам
SESSIONS_FILE=sessions.json
SOCIAL_DB_PATH=social.db
UPLOAD_DIR=static/uploads